<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_mobile" model="ir.ui.view">
        <field name="name">product.template.form.mobile.store.ai</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <field name="description_sale" position="before">
                <group string="Mobile Phone Specifications" name="mobile_specs">
                    <group>
                        <field name="brand_id" options="{'no_create': False}" />
                        <field name="model_year" />
                        <field name="ram" />
                        <field name="storage" />
                    </group>
                    <group>
                        <field name="processor" />
                        <field name="camera" />
                        <field name="battery" />
                        <field name="color" />
                    </group>
                </group>
                <field name="display_specs" position="after" />
            </field>
            <field name="list_price" position="after">
                <field name="display_specs" readonly="1" />
            </field>
        </field>
    </record>

    <record id="view_product_template_tree_inherit_mobile" model="ir.ui.view">
        <field name="name">product.template.tree.mobile.store.ai</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view" />
        <field name="arch" type="xml">
            <field name="product_brand_id" position="replace">
                <field name="brand_id" optional="show" />
            </field>
            <field name="list_price" position="after">
                <field name="ram" optional="hide" />
                <field name="storage" optional="hide" />
            </field>
        </field>
    </record>

    <record id="view_product_template_search_inherit_mobile" model="ir.ui.view">
        <field name="name">product.template.search.mobile.store.ai</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="brand_id" />
                <field name="ram" />
                <field name="storage" />
            </field>
        </field>
    </record>
</odoo>
